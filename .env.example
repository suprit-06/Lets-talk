# Postgre# Database URL (Use SQLite for local, PostgreSQL for Vercel/Production)
# Example for Neon: postgresql+asyncpg://user:pass@ep-empty-name-123456.us-east-2.aws.neon.tech/neondb
DATABASE_URL=sqlite+aiosqlite:///./ai_chat.db

# JWT settings
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 1 day

# AI Provider Settings
AI_PROVIDER=ollama # Set to 'openai' for Vercel/Production
OPENAI_API_BASE=http://localhost:11434 # Not needed for OpenAI
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=llama3 # e.g., 'gpt-4o' for OpenAI
