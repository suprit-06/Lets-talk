# Postgre# Database URL (Use SQLite for local, PostgreSQL for Vercel/Production)
# Example for Neon: postgresql+asyncpg://user:pass@ep-empty-name-123456.us-east-2.aws.neon.tech/neondb
DATABASE_URL=sqlite+aiosqlite:///./ai_chat.db

# JWT settings
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 1 day

# Groq API Settings
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant
